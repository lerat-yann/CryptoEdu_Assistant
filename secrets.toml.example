# ══════════════════════════════════════════════════════════════════════════════
# CryptoEdu Assistant — Template secrets.toml
# ══════════════════════════════════════════════════════════════════════════════
# Copiez ce fichier dans .streamlit/secrets.toml et remplissez les valeurs.
# NE JAMAIS commiter secrets.toml dans git !

# ── Clés LLM (au moins une obligatoire) ──────────────────────────────────────
GROQ_API_KEY = "gsk_..."
OPENROUTER_API_KEY = "sk-or-..."

# ── Google OAuth2 (optionnel — pour Gmail + Google Docs) ─────────────────────
# Créez vos identifiants sur : https://console.cloud.google.com/apis/credentials
# Type : Application Web
# URIs de redirection autorisés :
#   - http://localhost:8501  (dev local)
#   - https://votre-app.streamlit.app  (production)

GOOGLE_CLIENT_ID = "xxxxxxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET = "GOCSPX-xxxxxxxxxxxx"

# URI de redirection (doit correspondre à celle configurée dans Google Cloud)
# En local, laissez http://localhost:8501
# En production, mettez l'URL de votre app Streamlit Cloud
GOOGLE_REDIRECT_URI = "http://localhost:8501"
