# ── CryptoEdu Assistant — Variables d'environnement ──────────
# Copiez ce fichier en .env et remplissez les valeurs.

# OpenRouter (obligatoire) — Créez un compte sur https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-...

# ── Google OAuth2 (optionnel) ─────────────────────────────────
# Pour activer le bouton "Connexion Google" dans la sidebar.
# Créez des credentials OAuth2 dans Google Cloud Console.
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_REDIRECT_URI=http://localhost:8501

# ── Composio MCP (optionnel) ──────────────────────────────────
# Pour activer Gmail et Google Docs via Composio MCP.
# 1. Créez un compte sur https://composio.dev
# 2. Récupérez votre clé API dans Settings > API Keys
# 3. Connectez Gmail et Google Docs : composio add gmail googledocs
COMPOSIO_API_KEY=
